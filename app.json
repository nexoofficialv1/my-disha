{
  "expo": {
    "name": "DISHA",
    "slug": "disha",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "disha",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#073B7A"
    },
    "android": {
      "package": "com.astratechnologies.disha",
      "permissions": [
        "INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#073B7A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "company": "ASTRA Technologies"
    },
    "icon": "./assets/icon.png"
  }
}